generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  passwordHash  String         @map("password_hash")
  role          Role           @default(USER)
  isBanned      Boolean        @default(false) @map("is_banned")
  banReason     String?        @map("ban_reason")
  activeBanId   String?        @map("active_ban_id")
  isPaused      Boolean        @default(false) @map("is_paused")
  themeColor    String         @default("#00ABED") @map("theme_color")
  totalPlayTime Int            @default(0) @map("total_play_time") // seconds
  createdAt     DateTime       @default(now()) @map("created_at")
  lastLogin     DateTime?      @map("last_login")
  activities    Activity[]
  notifications Notification[]
  savedCookies  SavedCookie[]

  @@map("users")
}

model GuestSession {
  id          String    @id @default(cuid())
  fingerprint String    @unique
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  country     String?
  city        String?
  isPaused    Boolean   @default(false) @map("is_paused")
  lastSeen    DateTime  @default(now()) @map("last_seen")
  createdAt   DateTime  @default(now()) @map("created_at")
  convertedUserId String? @map("converted_user_id")

  @@index([lastSeen])
  @@map("guest_sessions")
}

model AdminCommand {
  id        String   @id @default(cuid())
  targetId  String?  @map("target_id")    // null = broadcast to all
  type      String                         // "ban" | "unban" | "pause" | "unpause" | "message" | "redirect"
  payload   String   @db.Text             // JSON payload
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetId, consumed])
  @@index([createdAt])
  @@map("admin_commands")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  fromAdminId String?  @map("from_admin_id")
  title       String   @default("Staff Message")
  message     String
  redirectUrl String?  @map("redirect_url")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String   @default("Gamepad2")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  games       Game[]

  @@map("categories")
}

model Game {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  url         String
  thumbnail   String?
  categoryId  String     @map("category_id")
  isActive    Boolean    @default(true) @map("is_active")
  isFeatured  Boolean    @default(false) @map("is_featured")
  playCount   Int        @default(0) @map("play_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  category    Category   @relation(fields: [categoryId], references: [id])
  activities  Activity[]

  @@index([categoryId])
  @@index([title])
  @@map("games")
}

model Activity {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  gameId      String    @map("game_id")
  ipAddress   String?   @map("ip_address")
  deviceInfo  String?   @map("device_info")
  userAgent   String?   @map("user_agent")
  geolocation String?
  country     String?
  city        String?
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameId])
  @@index([startedAt])
  @@map("activities")
}

model SavedCookie {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String                         // cookie/localStorage key
  value     String   @db.Text              // cookie value (can be large)
  domain    String   @default("")          // origin domain of the game
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, domain])
  @@index([userId])
  @@map("saved_cookies")
}
